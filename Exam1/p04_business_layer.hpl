    <limit>0</limit>
    <sql>SELECT
    c.job_id,
    c.title,
    c.Kienbaum_ID,
    c.Firma,
    c.mcg_function,
    c.weeks_open,
    c.location,
    c.language,
    c.created,
    c.lastseen,
    c.deleted,
    c.temporary,
    c.homeoffice,
    s.sector,
    s.sector_EN
FROM core_x28_jobs c
LEFT JOIN (
    SELECT DISTINCT company_id, sector, sector_EN
    FROM stg_tm_tp_companies_sectors
) s ON c.Kienbaum_ID = s.company_id</sql>
