    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>azure_sql</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT 
    j.job_id,
    j.title,
    j.company_id,
    j.created,
    j.lastseen,
    j.location,
    j.language,
    j.deleted,
    j.temporary,
    j.homeoffice,
    c.Kienbaum_ID,
    c.Firma,
    f.[function] AS mcg_function,
    CEILING(DATEDIFF(day, j.created, '2020-07-08') / 7.0) AS weeks_open
FROM stg_x28_jobs j
LEFT JOIN (
    SELECT cmp_id, Kienbaum_ID, Firma
    FROM (
        SELECT cmp_id, Kienbaum_ID, Firma,
               ROW_NUMBER() OVER (PARTITION BY cmp_id ORDER BY Kienbaum_ID) AS rn
        FROM stg_tm_x28_companies
    ) x
    WHERE rn = 1
) c ON TRY_CAST(j.company_id AS FLOAT) = c.cmp_id
LEFT JOIN (
    SELECT job_id, meta_id
    FROM (
        SELECT job_id, meta_id,
               ROW_NUMBER() OVER (PARTITION BY job_id ORDER BY meta_id) AS rn
        FROM stg_x28_job_meta
        WHERE meta_type = 'JOB'
    ) y
    WHERE rn = 1
) m ON j.job_id = m.job_id
LEFT JOIN (
    SELECT job_id_x28, [function]
    FROM (
        SELECT job_id_x28, [function],
               ROW_NUMBER() OVER (
                   PARTITION BY job_id_x28
                   ORDER BY [function]
               ) AS rn
        FROM stg_tm_x28_functions
    ) z
    WHERE rn = 1
) f ON m.meta_id = f.job_id_x28;</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>128</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
